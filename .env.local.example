# Neon PostgreSQL (kopieer connection string uit Neon dashboard)
DATABASE_URL=postgresql://username:password@host/dbname?sslmode=require

# E-mail (Gmail voorbeeld — gebruik app-wachtwoord!)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=jouw@gmail.com
SMTP_PASS=app-wachtwoord-hier
ADMIN_EMAIL=jouw@gmail.com

# Mollie (iDEAL) — kopieer je API-sleutel uit het Mollie dashboard.
# Gebruik test_... om te testen, live_... voor echte betalingen.
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxx
# Publieke URL van de site (voor Mollie redirect + webhook). In productie verplicht.
NEXT_PUBLIC_BASE_URL=https://www.citykistverhuurzwolle.nl

# Admin login — kies een sterk wachtwoord en een lang random secret.
# ADMIN_AUTH_SECRET kun je genereren met: openssl rand -hex 48
ADMIN_PASSWORD=kies-een-sterk-wachtwoord
ADMIN_AUTH_SECRET=zet-hier-een-lang-random-secret-van-minstens-48-bytes

# Factuurgegevens — verschijnen op de PDF-factuur. KvK en BTW-id zijn wettelijk
# verplicht op een geldige factuur; IBAN en adres zijn aanbevolen.
FACTUUR_KVK=
FACTUUR_BTW=
FACTUUR_IBAN=
FACTUUR_ADRES=
